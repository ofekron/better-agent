{
  "kind": "better-agent-extension",
  "id": "ofek-dev.memory",
  "name": "Memory",
  "version": "0.1.0",
  "description": "Cross-provider agent memory: agents propose memories for user approval/edit; the user can browse and edit memories any time.",
  "surfaces": [
    "frontend_feature",
    "runtime_mcp",
    "skills"
  ],
  "entrypoints": {
    "frontend": "ui/index.html",
    "frontend_modules": [
      {
        "slot": "settings",
        "id": "memory",
        "label": "Memory",
        "kind": "iframe",
        "module": "ui/index.html"
      }
    ],
    "mcp": [
      {
        "name": "ofek-dev-memory",
        "python": "mcp/server.py",
        "args": [],
        "env": {},
        "user_facing": true,
        "bare_allowed": true,
        "requires_backend_auth": true
      }
    ],
    "skills": [
      {
        "name": "writing-memories",
        "path": "skills/writing-memories",
        "default_enabled": true,
        "requires_mcp": ["ofek-dev-memory"]
      }
    ]
  },
  "permissions": {
    "internal_loopback": true
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "ui/index.html",
        "mcp/server.py",
        "skills/writing-memories/SKILL.md"
      ],
      "python_modules": [
        "mcp.server"
      ]
    }
  }
}
