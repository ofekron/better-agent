{
  "kind": "better-agent-extension",
  "id": "ofek-dev.marketplace",
  "name": "Marketplace",
  "version": "0.1.0",
  "description": "Search the Better Agent extension catalog and manage installed extensions.",
  "surfaces": [
    "runtime_mcp"
  ],
  "entrypoints": {
    "mcp": [
      {
        "name": "ofek-dev-marketplace",
        "python": "mcp/server.py",
        "args": [],
        "env": {},
        "user_facing": true,
        "bare_allowed": false,
        "requires_backend_auth": true
      }
    ]
  },
  "permissions": {
    "internal_loopback": true
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "mcp/server.py"
      ],
      "python_modules": [
        "mcp.server"
      ]
    }
  }
}
