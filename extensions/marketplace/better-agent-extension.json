{
  "kind": "better-agent-extension",
  "id": "ofek-dev.marketplace",
  "name": "Marketplace",
  "version": "0.2.0",
  "description": "Browse the Better Agent extension catalog and manage installed extensions.",
  "surfaces": [
    "frontend_feature",
    "backend_feature",
    "runtime_mcp"
  ],
  "entrypoints": {
    "frontend": "ui/index.html",
    "frontend_modules": [
      {
        "slot": "settings",
        "id": "marketplace",
        "label": "Marketplace",
        "kind": "iframe",
        "module": "ui/index.html"
      }
    ],
    "mcp": [
      {
        "name": "ofek-dev-marketplace",
        "python": "mcp/server.py",
        "args": [],
        "env": {},
        "user_facing": true,
        "bare_allowed": false,
        "requires_backend_auth": true
      }
    ],
    "backend_module": "backend.routes"
  },
  "permissions": {
    "backend_routes": true,
    "marketplace_auth": true,
    "capabilities": [
      "marketplace.search",
      "marketplace.installed.list",
      "marketplace.installed.get",
      "marketplace.install",
      "marketplace.enabled.set",
      "marketplace.uninstall",
      "marketplace.update"
    ]
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "ui/index.html",
        "mcp/server.py",
        "backend/routes.py"
      ],
      "python_modules": [
        "mcp.server",
        "backend.routes"
      ]
    }
  }
}
