{
  "kind": "better-agent-extension",
  "id": "ofek-dev.provider-config-sync",
  "name": "Provider Config Sync",
  "version": "0.1.0",
  "description": "Provider capability picker, config sync UI, and provider-config-sync MCP gates.",
  "surfaces": [
    "backend_feature",
    "runtime_mcp",
    "frontend_feature"
  ],
  "entrypoints": {
    "backend": "backend/routes.py",
    "frontend": "",
    "page": {
      "label": "Provider Config Sync",
      "open": {
        "type": "navigate",
        "path": "/provider-config-sync"
      }
    },
    "mcp": [
      {
        "name": "better-agent-provider-config-sync",
        "replaces_builtin": "provider-config-sync",
        "args": [],
        "env": {},
        "interacts_with_user": true,
        "bare_allowed": false,
        "requires_backend_auth": true,
        "native_exposure": {
          "allowed": true,
          "permissions": [
            "provider-config-sync.state.get",
            "provider-config-sync.capability-picker.get",
            "provider-config-sync.settings.get",
            "provider-config-sync.settings.patch",
            "provider-config-sync.repository.get",
            "provider-config-sync.repository.init",
            "provider-config-sync.repository.load",
            "provider-config-sync.repository.sync",
            "provider-config-sync.file.put",
            "provider-config-sync.file.restore",
            "provider-config-sync.capability.delete",
            "provider-config-sync.capability.create",
            "provider-config-sync.capability.transfer",
            "provider-config-sync.apply",
            "provider-config-sync.auto-sync",
            "provider-config-sync.unified-item.upsert",
            "provider-config-sync.unified-item.remove",
            "provider-config-sync.change.broadcast"
          ]
        },
        "python": "mcp/server.py"
      }
    ],
    "provider_capabilities": []
  },
  "permissions": {
    "session_state": true,
    "filesystem": true,
    "provider_config": true,
    "backend_routes": true,
    "capabilities": [
      "provider-config-sync.state.get",
      "provider-config-sync.capability-picker.get",
      "provider-config-sync.settings.get",
      "provider-config-sync.settings.patch",
      "provider-config-sync.repository.get",
      "provider-config-sync.repository.init",
      "provider-config-sync.repository.load",
      "provider-config-sync.repository.sync",
      "provider-config-sync.file.put",
      "provider-config-sync.file.restore",
      "provider-config-sync.capability.delete",
      "provider-config-sync.capability.create",
      "provider-config-sync.capability.transfer",
      "provider-config-sync.apply",
      "provider-config-sync.auto-sync",
      "provider-config-sync.unified-item.upsert",
      "provider-config-sync.unified-item.remove",
      "provider-config-sync.change.broadcast"
    ]
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "backend/routes.py",
        "better-agent-extension.json",
        "mcp/server.py"
      ],
      "python_modules": [
        "mcp.server"
      ]
    }
  }
}
