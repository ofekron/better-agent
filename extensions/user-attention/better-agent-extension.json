{
  "kind": "better-agent-extension",
  "id": "ofek-dev.user-attention",
  "name": "User attention",
  "version": "0.2.0",
  "description": "Marks a session for the user's attention: an orange dot when the agent surfaces something needing a decision, and a blue dot when the agent reports all tasks are done. The marker clears when the user views the session.",
  "surfaces": [
    "instructions"
  ],
  "entrypoints": {
    "instructions": [
      {
        "name": "user-attention",
        "path": "instructions/user_attention.md",
        "level": "global"
      }
    ],
    "applied_config": {
      "tag_rules": [
        {
          "tag": "NEEDS_USER_DECISION",
          "strip_wrapper": true,
          "style": {
            "bold": true,
            "font_scale": 1.3,
            "highlight": {
              "color": "#d29922",
              "alpha": 0.18
            }
          },
          "marker": {
            "color": "#d29922",
            "tooltip": "Needs your decision",
            "sound": true
          },
          "clear_on": "view"
        },
        {
          "tag": "ALL_TASKS__DONE",
          "strip_wrapper": true,
          "marker": {
            "color": "#2563eb",
            "tooltip": "All tasks done",
            "sound": false
          },
          "clear_on": "view"
        }
      ]
    }
  },
  "permissions": {},
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "instructions/user_attention.md"
      ],
      "python_modules": []
    }
  }
}
