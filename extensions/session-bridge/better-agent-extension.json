{
  "kind": "better-agent-extension",
  "id": "ofek-dev.session-bridge",
  "name": "Session Bridge",
  "version": "0.1.0",
  "description": "User-facing cross-session operations: search sessions, delegate a prompt to its own session, and propose sessions.",
  "surfaces": [
    "backend_feature",
    "runtime_mcp",
    "frontend_feature"
  ],
  "entrypoints": {
    "backend": "backend/routes.py",
    "mcp": [
      {
        "name": "better-agent-session-bridge",
        "python": "mcp/server.py",
        "args": [],
        "env": {},
        "user_facing": true,
        "bare_allowed": false,
        "requires_backend_auth": true,
        "native_exposure": {
          "allowed": true,
          "permissions": [
            "session-bridge.sessions.search",
            "session-bridge.delegate",
            "session-bridge.sessions.propose",
            "session-bridge.delegation.resolve",
            "core.mcp-jobs.results"
          ]
        },
        "predicate": {
          "equals": {
            "mode": "native"
          },
          "not_equals": {
            "app_session_id": "ask-singleton",
            "working_mode": "search_worker"
          }
        }
      }
    ]
  },
  "permissions": {
    "backend_routes": true,
    "session_state": true,
    "capabilities": [
      "session-bridge.sessions.search",
      "session-bridge.delegate",
      "session-bridge.sessions.propose",
      "session-bridge.delegation.resolve",
      "core.mcp-jobs.results"
    ]
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "backend/routes.py",
        "better-agent-extension.json",
        "mcp/server.py"
      ],
      "python_modules": [
        "mcp.server"
      ]
    }
  }
}
