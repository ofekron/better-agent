{
  "kind": "better-agent-extension",
  "id": "ofek-dev.switch-control",
  "name": "Line Switch",
  "version": "0.3.0",
  "description": "Keeps development-line supervisor metadata available to Better Agent Switch.",
  "surfaces": [
    "instructions",
    "daemons"
  ],
  "entrypoints": {
    "instructions": [
      {
        "name": "switch-lines",
        "path": "instructions/global.md",
        "level": "global"
      }
    ],
    "daemons": [
      {
        "name": "line-switch",
        "module": "line_switch_runtime.service",
        "lifecycle": "supervisor",
        "restart_policy": {
          "max_restarts": 5,
          "backoff_seconds": 1
        }
      }
    ]
  },
  "permissions": {
    "daemons": "supervisor"
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "instructions/global.md"
      ],
      "python_modules": [
        "line_switch_runtime.service"
      ]
    }
  }
}
