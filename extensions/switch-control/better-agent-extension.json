{
  "kind": "better-agent-extension",
  "id": "ofek-dev.switch-control",
  "name": "Line Switch",
  "version": "0.3.0",
  "description": "Switch the running backend+frontend between development lines through a backend-independent supervisor daemon.",
  "surfaces": [
    "backend_feature",
    "frontend_feature",
    "instructions",
    "daemons"
  ],
  "entrypoints": {
    "backend_module": "backend.routes",
    "frontend": "ui/index.html",
    "quick_button": {
      "label": "Line",
      "placements": ["settings"],
      "action": {
        "type": "module",
        "module_url": "ui/switch.entry.js"
      }
    },
    "instructions": [
      {
        "name": "switch-lines",
        "path": "instructions/global.md",
        "level": "global"
      }
    ],
    "daemons": [
      {
        "name": "line-switch",
        "module": "line_switch_runtime.service",
        "lifecycle": "supervisor",
        "restart_policy": {
          "max_restarts": 5,
          "backoff_seconds": 1
        },
        "ports": [18766]
      }
    ]
  },
  "permissions": {
    "backend_routes": true,
    "capabilities": [
      "switch-control.state.get",
      "switch-control.switch.request"
    ],
    "daemons": "supervisor"
  },
  "marketplace": {
    "product_id": "",
    "subscription_required": false,
    "entitlement_url": ""
  },
  "protocol": {
    "version": 1,
    "smoke_test": {
      "required_paths": [
        "better-agent-extension.json",
        "ui/index.html",
        "ui/switch.entry.js",
        "instructions/global.md"
      ],
      "python_modules": [
        "backend.routes",
        "line_switch_runtime.service"
      ]
    }
  }
}
