# PyInstaller build artifacts — regenerated by build_macos.sh.
build/
dist/

# Python bytecode caches.
__pycache__/
*.pyc

# tufup update-repo artifacts if a release is ever run in-tree. The
# keystore holds PRIVATE signing keys — never commit it. The published
# repository and tufup's config file are generated, not source.
keystore/
repository/
.tufup-repo-config
tufup_root.json
update_url.txt
