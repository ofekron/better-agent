frontend/dist/
frontend/releases/

backend/.venvs/
backend/.active-venv
backend/.dependency-plan.lock
backend/__pycache__/
**/__pycache__/
**/*.pyc

.better-claude/
.better-agent/
.routine-outputs/
.routine-reports/
.pytest_cache/
.cache_ggshield/
.cocoindex_code/

*.apk
