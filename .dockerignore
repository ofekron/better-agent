# Used by tests/install-smoke/Dockerfile's `COPY . /repo`. Keeps the
# clean-room install smoke test's build context to source only — the
# private nested repo, submodule sources, venvs, and node_modules are
# either huge, not needed by scripts/install.py, or both.
